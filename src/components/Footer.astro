---
/**
 * Footer — Giant Wordmark
 */
const year = new Date().getFullYear();
const socialLinks = [
  { href: "https://www.instagram.com/thesoftbunnyxx", label: "IG" },
  { href: "https://www.linkedin.com/in/sandriat", label: "LinkedIn" },
  { href: "https://www.beacons.ai/thesoftbunnyxx", label: "Beacons" },
];
---

<footer class="giant-footer">
  <div class="giant-footer__inner">

    <!-- Giant name -->
    <div class="giant-footer__name-block">
      <a href="#hero" class="giant-footer__name font-display" aria-label="Back to top">
        <span class="giant-footer__line1">sandria</span>
        <span class="giant-footer__line1">tran</span>
      </a>

      <nav class="giant-footer__socials" aria-label="Social links">
        {socialLinks.map((link, index) => (
          <Fragment key={link.href}>
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors duration-200"
            >
              {link.label === 'Instagram' ? 'IG' : link.label}
            </a>
            {index < socialLinks.length - 1 && (
              <span class="text-[var(--text-secondary)] opacity-40 select-none">&middot;</span>
            )}
          </Fragment>
        ))}
      </nav>
    </div>

    <!-- Bottom utility row -->
    <div class="giant-footer__bottom">
      <div class="giant-footer__left">
        <span class="giant-footer__status">
          <span class="giant-footer__pulse"></span>
          Available
        </span>
        <span class="giant-footer__dot">&middot;</span>
        <a href="mailto:s2890588@ed.ac.uk" class="giant-footer__cta">
          say hello <span class="giant-footer__arrow">&#8599;</span>
        </a>
      </div>
      <div class="giant-footer__right">
        <span class="giant-footer__copy">&copy; {year} Sandria Tran</span>
        <span class="giant-footer__dot">&middot;</span>
        <a href="#hero" class="giant-footer__top-link">
          Back to top
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="18 15 12 9 6 15"/></svg>
        </a>
      </div>
    </div>

  </div>
</footer>

<style>
  .giant-footer {
    position: relative;
    padding: 0 max(24px, 5vw);
    margin-top: 80px;
    overflow: hidden;
  }

  .giant-footer__inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 60px 0 32px;
    border-top: 1px solid var(--surface-border);
  }

  /* ─── Giant Name ─── */
  .giant-footer__name-block {
    margin-bottom: 40px;
    text-align: center;
  }

  .giant-footer__name {
    display: block;
    text-decoration: none;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    opacity: 0.12;
    transition: opacity 0.4s ease;
  }

  .giant-footer__name:hover {
    opacity: 0.25;
  }

  .giant-footer__line1 {
    display: block;
    font-size: clamp(4rem, 12vw, 10rem);
    font-weight: 200;
  }

  .giant-footer__socials {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: 24px;
    font-family: var(--font-accent);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  /* ─── Bottom utility row ─── */
  .giant-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 0.82rem;
    color: var(--text-secondary);
  }

  .giant-footer__left,
  .giant-footer__right {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .giant-footer__dot {
    opacity: 0.3;
  }

  /* Status */
  .giant-footer__status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--status-green);
    font-weight: 500;
  }

  .giant-footer__pulse {
    position: relative;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--status-green);
    flex-shrink: 0;
  }

  .giant-footer__pulse::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--status-green);
    animation: availability-ring 2s ease-out infinite;
  }

  @keyframes availability-ring {
    0%   { transform: scale(1); opacity: 0.7; }
    70%  { transform: scale(2.8); opacity: 0; }
    100% { transform: scale(1); opacity: 0; }
  }

  /* CTA link */
  .giant-footer__cta {
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s ease;
  }

  .giant-footer__cta:hover {
    opacity: 0.7;
  }

  .giant-footer__arrow {
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .giant-footer__cta:hover .giant-footer__arrow {
    transform: translate(2px, -2px);
  }

  /* Copyright */
  .giant-footer__copy {
    opacity: 0.5;
  }

  /* Back to top */
  .giant-footer__top-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--text-secondary);
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  .giant-footer__top-link:hover {
    opacity: 1;
  }

  /* ─── Mobile ─── */
  @media (max-width: 640px) {
    .giant-footer {
      margin-top: 60px;
    }

    .giant-footer__inner {
      padding: 40px 0 24px;
    }

    .giant-footer__name-block {
      margin-bottom: 28px;
    }

    .giant-footer__socials {
      margin-top: 16px;
    }

    .giant-footer__bottom {
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }
  }
</style>
