---
/**
 * Memories Section — "Polaroid Scatter" Layout
 *
 * Photos displayed as scattered Polaroid prints on a dark surface.
 * Each has a white border (thicker on bottom), slight random rotation,
 * and overlapping neighbours. Hover lifts a polaroid above the stack.
 * Click opens lightbox.
 *
 * Includes: tag filter bar, hover captions, random memory button.
 */

import fs from 'node:fs';
import path from 'node:path';
import { getMemoryMeta, ALL_TAGS } from '../data/memories';

const memoriesDir = path.resolve('public/images/memories');
let memoryImages: { src: string; filename: string; caption: string; tags: string[] }[] = [];

try {
  const files = fs.readdirSync(memoriesDir);
  memoryImages = files
    .filter((f: string) => /\.(webp|jpg|jpeg|png)$/i.test(f))
    .sort()
    .map((f: string) => {
      const meta = getMemoryMeta(f);
      return {
        src: `/images/memories/${f}`,
        filename: f,
        caption: meta?.caption ?? '',
        tags: meta?.tags ?? ALL_TAGS,
      };
    });
} catch {
  // Directory not populated yet
}

// Deterministic "random" values seeded from index
function seededValue(i: number, offset: number, min: number, max: number): number {
  const seed = ((i * 2654435761 + offset * 1597334677) >>> 0) / 4294967296;
  return min + seed * (max - min);
}

// Assign each polaroid to a "cluster" row to create organic grouping
function getClusterOffset(i: number): { marginTop: number; marginLeft: number } {
  return {
    marginTop: Math.round(seededValue(i, 10, -12, 12)),
    marginLeft: Math.round(seededValue(i, 20, -8, 8)),
  };
}
---

<section id="memories" class="relative">
  <div class="memory-reveal mb-10 text-center">
    <h2
      class="mb-3 font-display text-4xl tracking-tight sm:text-5xl"
      style="color: var(--text-primary);"
    >
      memories
    </h2>
  </div>

  {/* Random button */}
  <div class="memory-reveal mb-12 flex justify-center">
    <button class="memory-random-btn" id="memory-random-btn" aria-label="Open a random memory">
      <span class="memory-random-icon">↻</span>
      <span>surprise me</span>
    </button>
  </div>

  {memoryImages.length > 0 ? (
    <div class="polaroid-surface mx-auto w-full max-w-[1400px] px-8 sm:px-12">
      <div class="polaroid-grid" id="polaroid-grid">
        {memoryImages.map((mem, i) => {
          const rotation = seededValue(i, 1, -6, 6);
          const cluster = getClusterOffset(i);
          const delay = (i % 14) * 40;
          const zBase = Math.round(seededValue(i, 30, 1, 10));

          return (
            <figure
              class="memory-reveal polaroid-item"
              style={`
                --polaroid-rotation: ${rotation.toFixed(1)}deg;
                --reveal-delay: ${delay}ms;
                --z-base: ${zBase};
                margin-top: ${cluster.marginTop}px;
              `}
              data-lightbox-src={mem.src}
            >
              <div class="polaroid-frame">
                <div class="polaroid-image-wrap">
                  <img
                    src={mem.src}
                    alt={mem.caption || `Memory`}
                    loading="lazy"
                    class="polaroid-img"
                    style="background: var(--surface);"
                  />
                </div>
                {mem.caption && (
                  <div class="polaroid-caption" aria-hidden="true">{mem.caption}</div>
                )}
              </div>
            </figure>
          );
        })}
      </div>
    </div>
  ) : (
    <p class="text-center text-sm" style="color: var(--text-secondary);">
      Photos coming soon.
    </p>
  )}
</section>

<style>
  /* Surface — subtle dark desk texture */
  .polaroid-surface {
    position: relative;
  }

  /* Grid — wrapping flex with negative margins for overlap */
  .polaroid-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 4px;
    width: 100%;
  }

  @media (min-width: 640px) {
    .polaroid-grid {
      gap: 2px;
    }
  }

  /* Polaroid item */
  .polaroid-item {
    transform: rotate(var(--polaroid-rotation, 0deg));
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1),
                z-index 0s,
                filter 0.4s ease,
                opacity 0.35s ease,
                scale 0.35s ease;
    cursor: pointer;
    position: relative;
    z-index: var(--z-base, 1);
    width: calc(33.33% - 8px);
    min-width: 100px;
    flex-shrink: 0;
  }

  @media (min-width: 640px) {
    .polaroid-item {
      width: calc(20% - 2px);
    }
  }

  @media (min-width: 1024px) {
    .polaroid-item {
      width: calc(16.66% - 4px);
      margin: -8px 0;
    }
  }

  .polaroid-item:hover {
    transform: rotate(0deg) translateY(-14px) scale(1.05);
    z-index: 50 !important;
    filter: drop-shadow(0 16px 32px rgba(0, 0, 0, 0.25));
  }

  :global(.dark) .polaroid-item:hover {
    filter: drop-shadow(0 16px 32px rgba(0, 0, 0, 0.5));
  }

  /* Polaroid frame — white border, thicker on bottom */
  .polaroid-frame {
    background: #fafaf8;
    padding: 6px 6px 24px 6px;
    border-radius: 2px;
    box-shadow:
      0 2px 8px -2px rgba(0, 0, 0, 0.1),
      0 0 0 1px rgba(0, 0, 0, 0.04);
    transition: box-shadow 0.4s ease;
  }

  :global(.dark) .polaroid-frame {
    background: #f0ede8;
    box-shadow:
      0 2px 8px -2px rgba(0, 0, 0, 0.3),
      0 0 0 1px rgba(0, 0, 0, 0.1);
  }

  @media (min-width: 640px) {
    .polaroid-frame {
      padding: 8px 8px 32px 8px;
    }
  }

  /* Image area */
  .polaroid-image-wrap {
    overflow: hidden;
    aspect-ratio: 1;
    background: #e8e8e4;
  }

  .polaroid-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .polaroid-item:hover .polaroid-img {
    transform: scale(1.04);
  }

  /* Caption strip — shows text in the white bottom area */
  .polaroid-caption {
    margin-top: 6px;
    font-family: 'Montserrat', sans-serif;
    font-size: 8px;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    color: #999;
    text-align: center;
    opacity: 0;
    transition: opacity 0.25s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    padding: 0 4px;
  }

  .polaroid-item:hover .polaroid-caption {
    opacity: 1;
  }

  /* Scroll reveal */
  .memory-reveal {
    opacity: 0;
    transform: translateY(20px) rotate(var(--polaroid-rotation, 0deg));
  }

  .memory-reveal.visible {
    opacity: 1;
    transform: translateY(0) rotate(var(--polaroid-rotation, 0deg));
    transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }

  /* Random button */
  .memory-random-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 28px;
    border-radius: 9999px;
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: lowercase;
    cursor: pointer;
    border: 1px solid rgba(210, 191, 214, 0.5);
    background: rgba(210, 191, 214, 0.12);
    color: var(--text-primary);
    backdrop-filter: blur(12px);
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
    outline: none;
    box-shadow: 0 0 20px rgba(210, 191, 214, 0.15), inset 0 0 12px rgba(255,255,255,0.04);
  }

  .memory-random-btn:hover {
    background: rgba(210, 191, 214, 0.22);
    border-color: rgba(210, 191, 214, 0.8);
    transform: translateY(-1px);
    box-shadow: 0 4px 24px rgba(210, 191, 214, 0.3), inset 0 0 12px rgba(255,255,255,0.06);
  }

  .memory-random-btn:active {
    transform: translateY(0px);
  }

  .memory-random-icon {
    display: inline-block;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .memory-random-btn:hover .memory-random-icon {
    transform: rotate(180deg);
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .polaroid-item,
    .polaroid-img,
    .polaroid-frame,
    .memory-reveal {
      transition: none !important;
    }
    .polaroid-item { transform: none !important; }
    .memory-reveal { opacity: 1; transform: none; }
  }
</style>

<script>
  // Scroll reveal
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.05 }
  );
  document.querySelectorAll('.memory-reveal').forEach((el) => observer.observe(el));

  // Lightbox
  document.querySelectorAll('.polaroid-item').forEach((item) => {
    item.addEventListener('click', () => {
      const src = (item as HTMLElement).dataset.lightboxSrc;
      if (src) {
        window.dispatchEvent(new CustomEvent('open-lightbox', { detail: { src } }));
      }
    });
  });

  // Random memory
  const polaroids = document.querySelectorAll<HTMLElement>('.polaroid-item');
  document.getElementById('memory-random-btn')?.addEventListener('click', () => {
    const all = Array.from(polaroids);
    if (all.length === 0) return;
    const pick = all[Math.floor(Math.random() * all.length)] as HTMLElement;
    const src = pick.dataset.lightboxSrc;
    if (src) {
      window.dispatchEvent(new CustomEvent('open-lightbox', { detail: { src } }));
    }
  });
</script>
