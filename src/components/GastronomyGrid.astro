---
/**
 * Gastronomy Section — Masonry Photo Grid with hover narrative cards
 */

import fs from 'node:fs';
import path from 'node:path';
import { getDishMeta } from '../data/gastronomy';

const gastroDir = path.resolve('public/images/gastronomy');
let images: { src: string; alt: string; name?: string; story?: string; season?: string }[] = [];

try {
  const files = fs.readdirSync(gastroDir);
  const isUUID = (name: string) => /^[0-9A-F]{8}-[0-9A-F]{4}/i.test(name);
  const isScreenshot = (name: string) => /^Screen/i.test(name);
  const isIMG = (name: string) => /^IMG[_-]/i.test(name);

  const allImages = files
    .filter((f: string) => /\.(webp|jpg|jpeg|png)$/i.test(f))
    .sort()
    .map((f: string) => {
      const baseName = f.replace(/\.(webp|jpg|jpeg|png)$/i, '');
      let alt: string = '';
      if (!isUUID(baseName) && !isScreenshot(baseName) && !isIMG(baseName)) {
        alt = baseName.replace(/[-_+]/g, ' ').replace(/\s+/g, ' ').trim();
        alt = alt.charAt(0).toUpperCase() + alt.slice(1);
      }
      const meta = getDishMeta(f);
      return {
        src: `/images/gastronomy/${f}`,
        alt: meta?.name || alt,
        name: meta?.name,
        story: meta?.story,
        season: meta?.season,
      };
    });

  const seen = new Set<string>();
  images = allImages.filter(img => {
    const base = img.src.replace(/[-\s]*\(\d+\)/, '');
    if (seen.has(base)) return false;
    seen.add(base);
    return true;
  });
} catch {
  // Directory not populated yet
}

const getSpanClass = (i: number): string => {
  if (i === 0) return 'col-span-2 row-span-2';
  if (i % 7 === 3) return 'col-span-2 row-span-2';
  if (i % 9 === 5) return 'col-span-2';
  return '';
};
---

<section id="gastronomy" class="relative">
  <div class="mx-auto w-full max-w-[1400px] px-8 sm:px-12">
    <div class="gastro-reveal mb-14 text-center">
      <h2
        class="mb-3 font-display text-4xl tracking-tight sm:text-5xl"
        style="color: var(--text-primary);"
      >
        gastronomy
      </h2>
    </div>

    <div class="grid grid-flow-row-dense auto-rows-[180px] grid-cols-2 gap-3 overflow-hidden sm:auto-rows-[220px] sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
    {images.map((img, i) => (
      <figure
        class={`gastro-reveal gastro-item group relative cursor-pointer overflow-hidden rounded-xl ${getSpanClass(i)}`}
        style={`--reveal-delay: ${(i % 10) * 60}ms;`}
        data-lightbox-src={img.src}
      >
        <img
          src={img.src}
          alt={img.alt}
          loading="lazy"
          class="h-full w-full rounded-xl object-cover transition-transform duration-500 group-hover:scale-105"
          style="background: var(--surface);"
        />
        {(img.name || img.story) && (
          <div class="gastro-overlay absolute inset-0 flex flex-col justify-end rounded-xl p-4 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
            {img.name && (
              <p class="gastro-dish-name mb-1 font-serif italic leading-tight">{img.name}</p>
            )}
            {img.story && (
              <p class="gastro-dish-story leading-snug">{img.story}</p>
            )}
            {img.season && (
              <span class="gastro-season mt-2 inline-block self-start rounded-full px-2 py-0.5 font-accent text-[9px] uppercase tracking-widest">{img.season}</span>
            )}
          </div>
        )}
      </figure>
    ))}
    </div>
  </div>
</section>

<style>
  .gastro-reveal {
    opacity: 0;
    transform: translateY(24px);
  }
  .gastro-reveal.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.6s ease, transform 0.6s ease;
    transition-delay: var(--reveal-delay, 0ms);
  }

  .gastro-overlay {
    background: linear-gradient(transparent 15%, rgba(0, 0, 0, 0.72) 60%);
    backdrop-filter: blur(0px);
  }

  .gastro-dish-name {
    color: #ffffff;
    font-size: clamp(0.85rem, 1.4vw, 1.1rem);
    font-family: 'Cormorant Garamond', Georgia, serif;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }

  .gastro-dish-story {
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(0.65rem, 0.9vw, 0.75rem);
    font-family: 'Lexend Deca', sans-serif;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .gastro-season {
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: rgba(255, 255, 255, 0.75);
    font-family: 'Montserrat', sans-serif;
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll('.gastro-reveal').forEach((el) => observer.observe(el));

  document.querySelectorAll('.gastro-item').forEach((item) => {
    item.addEventListener('click', () => {
      const src = (item as HTMLElement).dataset.lightboxSrc;
      if (src) {
        window.dispatchEvent(new CustomEvent('open-lightbox', { detail: { src } }));
      }
    });
  });
</script>
